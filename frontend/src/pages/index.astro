---
// Custom landing page — not a Starlight doc page
// Bypasses the Starlight layout entirely to render a full-screen hero
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { Icon } from 'astro-icon/components';

const installSnippet = `git clone https://github.com/javirm3/TFM
cd TFM/code
uv sync

# optional: include notebook extras
uv sync --extra notebooks

uv run glmhmmt-fit-glmhmmt --help
uv run marimo edit notebooks/glmhmmt_analysis.py`;

const installOneLiner = 'git clone https://github.com/javirm3/TFM && cd TFM/code && uv sync --extra notebooks';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>glmhmmt — Softmax GLM-HMM on Dynamax</title>
  <meta name="description" content="A Softmax Generalised Linear Model Hidden Markov Model built on top of Dynamax, for cognitive neuroscience research at IDIBAPS." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #09121e;
      color: #e2eaf5;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2.5rem;
      height: 60px;
      background: rgba(9, 18, 30, 0.7);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(74, 158, 255, 0.12);
    }

    .nav-brand {
      font-size: 1.05rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: #4a9eff;
      text-decoration: none;
    }

    .nav-brand span {
      color: #8bc4ff;
      font-weight: 300;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      color: #8ba8cc;
      text-decoration: none;
      font-size: 0.875rem;
      font-weight: 500;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: #4a9eff; }

    @media (max-width: 640px) {
      nav {
        padding: 0.75rem 1rem;
        height: auto;
        flex-direction: column;
        gap: 0.75rem;
      }
      .nav-links {
        gap: 1.25rem;
        flex-wrap: wrap;
        justify-content: center;
      }
    }

    /* ── HERO / CANVAS ── */
    #hero {
      position: relative;
      width: 100%;
      height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    #waveCanvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    .hero-content {
      position: relative;
      z-index: 10;
      text-align: center;
      max-width: 820px;
      padding: 0 2rem;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.35rem 0.9rem;
      background: rgba(30, 106, 191, 0.18);
      border: 1px solid rgba(74, 158, 255, 0.3);
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 500;
      color: #4a9eff;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 1.6rem;
    }

    .hero-badge::before {
      content: '';
      width: 6px; height: 6px;
      border-radius: 50%;
      background: #4a9eff;
      animation: pulse-dot 2s ease-in-out infinite;
    }

    @keyframes pulse-dot {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.4; transform: scale(0.8); }
    }

    .hero-title {
      font-size: clamp(2.8rem, 6vw, 5rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1.1;
      color: #e8f1ff;
      margin-bottom: 1.2rem;
    }

    .hero-title .accent {
      background: linear-gradient(135deg, #4a9eff 0%, #1e6abf 60%, #8bc4ff 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-sub {
      font-size: 1.1rem;
      font-weight: 300;
      color: #7a9abf;
      line-height: 1.7;
      max-width: 580px;
      margin: 0 auto 2.4rem;
    }

    .hero-sub code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.9em;
      color: #4a9eff;
      background: rgba(74, 158, 255, 0.1);
      padding: 0.1em 0.4em;
      border-radius: 4px;
    }

    .hero-cta {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.75rem;
      border-radius: 8px;
      font-size: 0.92rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.2s;
      cursor: pointer;
    }

    .btn-primary {
      background: linear-gradient(135deg, #1e6abf, #1358a0);
      color: #e8f1ff;
      border: 1px solid rgba(74, 158, 255, 0.4);
      box-shadow: 0 4px 24px rgba(30, 106, 191, 0.3);
    }

    .btn-primary:hover {
      background: linear-gradient(135deg, #2278d4, #1a6bbf);
      box-shadow: 0 6px 32px rgba(30, 106, 191, 0.5);
      transform: translateY(-1px);
    }

    .btn-ghost {
      background: rgba(74, 158, 255, 0.06);
      color: #8bc4ff;
      border: 1px solid rgba(74, 158, 255, 0.2);
    }

    .btn-ghost:hover {
      background: rgba(74, 158, 255, 0.12);
      color: #c0dcff;
      transform: translateY(-1px);
    }

    /* ── SCROLL HINT ── */
    .scroll-hint {
      position: absolute;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      color: #3a5a7a;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .scroll-arrow {
      width: 20px; height: 20px;
      border-right: 2px solid #1e4d8c;
      border-bottom: 2px solid #1e4d8c;
      transform: rotate(45deg);
      animation: bounce 1.6s ease-in-out infinite;
    }

    @keyframes bounce {
      0%, 100% { transform: rotate(45deg) translateY(0); opacity: 0.5; }
      50% { transform: rotate(45deg) translateY(5px); opacity: 1; }
    }

    /* ── FEATURES ── */
    #features {
      padding: 6rem 2rem;
      max-width: 1100px;
      margin: 0 auto;
    }

    .section-label {
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #4a9eff;
      margin-bottom: 0.8rem;
    }

    .section-title {
      font-size: clamp(1.8rem, 3vw, 2.6rem);
      font-weight: 700;
      letter-spacing: -0.025em;
      color: #d0e4f7;
      margin-bottom: 1rem;
    }

    .section-desc {
      color: #5a7a9a;
      font-size: 1rem;
      line-height: 1.7;
      max-width: 560px;
      margin-bottom: 3.5rem;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .feature-card {
      background: rgba(14, 28, 50, 0.7);
      border: 1px solid rgba(30, 77, 140, 0.35);
      border-radius: 12px;
      padding: 1.75rem;
      transition: border-color 0.2s, transform 0.2s;
    }

    .feature-card:hover {
      border-color: rgba(74, 158, 255, 0.45);
      transform: translateY(-3px);
    }

    .feature-icon {
      width: 44px; height: 44px;
      border-radius: 10px;
      background: rgba(30, 106, 191, 0.15);
      border: 1px solid rgba(74, 158, 255, 0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.3rem;
      color: #4a9eff;
      margin-bottom: 1.1rem;
    }

    .feature-icon [data-icon] {
      width: 1.35rem;
      height: 1.35rem;
      stroke-width: 1.8;
    }

    .feature-title {
      font-size: 1rem;
      font-weight: 600;
      color: #c8dcf0;
      margin-bottom: 0.5rem;
    }

    .feature-desc {
      font-size: 0.875rem;
      color: #5a7a9a;
      line-height: 1.65;
    }

    /* ── QUICK INSTALL SNIPPET ── */
    #install {
      padding: 5rem 2rem;
      background: rgba(10, 22, 40, 0.8);
      border-top: 1px solid rgba(30, 77, 140, 0.2);
      border-bottom: 1px solid rgba(30, 77, 140, 0.2);
      text-align: center;
    }

    .code-block {
      display: inline-block;
      background: #0b1a2e;
      border: 1px solid rgba(30, 77, 140, 0.5);
      border-radius: 10px;
      padding: 1.2rem 2rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.95rem;
      color: #4a9eff;
      margin: 1.5rem 0 0; /* removed bottom margin to give space for subtext */
      text-align: left;
      position: relative;
      max-width: 520px;
      width: 100%;
    }

    .code-block .comment { color: #2a5a8a; user-select: none; }
    .code-block .cmd     { color: #8bc4ff; }
    .code-block .kw      { color: #4a9eff; }

    /* Copy Button */
    .copy-btn {
      position: absolute;
      top: 0.75rem;
      right: 0.75rem;
      background: rgba(30, 106, 191, 0.15);
      border: 1px solid rgba(74, 158, 255, 0.2);
      color: #8bc4ff;
      border-radius: 6px;
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.2s;
    }
    
    .copy-btn:hover {
      background: rgba(74, 158, 255, 0.15);
      color: #fff;
    }

    .copy-btn [data-icon] {
      width: 1rem;
      height: 1rem;
    }

    .install-note {
      font-size: 0.85rem;
      color: #5a7a9a;
      margin: 1rem auto 2.5rem;
      max-width: 520px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }

    .install-note [data-icon] {
      color: #4a9eff;
      font-size: 1.1rem;
    }

    .bottom-install {
      padding: 2rem;
    }

    .bottom-install-card {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
      padding: 1.1rem 1.25rem;
      border-radius: 14px;
      background: rgba(14, 28, 50, 0.78);
      border: 1px solid rgba(74, 158, 255, 0.18);
      box-shadow: 0 10px 40px rgba(5, 12, 22, 0.22);
    }

    .bottom-install-copy {
      min-width: 0;
      flex: 1;
    }

    .bottom-install-kicker {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #4a9eff;
      margin-bottom: 0.45rem;
    }

    .bottom-install-title {
      font-size: 1rem;
      font-weight: 600;
      color: #d7e7f7;
      margin-bottom: 0.6rem;
    }

    .bottom-install-command {
      display: block;
      width: 100%;
      overflow-x: auto;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.86rem;
      color: #8bc4ff;
      white-space: nowrap;
      padding: 0.8rem 0.95rem;
      border-radius: 10px;
      background: rgba(9, 18, 30, 0.82);
      border: 1px solid rgba(74, 158, 255, 0.15);
    }

    .bottom-install-actions {
      display: flex;
      gap: 0.75rem;
      align-items: center;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .copy-action {
      min-width: 180px;
      justify-content: center;
    }

    .copy-action [data-icon] {
      width: 1rem;
      height: 1rem;
    }

    @media (max-width: 820px) {
      .bottom-install-card {
        flex-direction: column;
        align-items: stretch;
      }

      .bottom-install-actions {
        justify-content: stretch;
      }

      .copy-action,
      .bottom-install-actions .btn {
        width: 100%;
      }
    }

    /* ── FOOTER ── */
    footer {
      padding: 2.5rem 2.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-top: 1px solid rgba(30, 77, 140, 0.15);
      flex-wrap: wrap;
      gap: 1rem;
      color: #2a4a6a;
      font-size: 0.8rem;
    }

    footer a {
      color: #2a5a8a;
      text-decoration: none;
    }

    footer a:hover { color: #4a9eff; }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav>
    <a class="nav-brand" href="/">glmhmm<span>t</span></a>
    <ul class="nav-links">
