        <Icon name="lucide:check" id="checkIcon" data-check-icon style="display: none;" />
      </button>
      <div id="code-content">
<span class="comment"># clone and install with uv</span><br/>
<span class="cmd">git clone</span> https://github.com/javirm3/TFM<br/>
<span class="cmd">cd</span> TFM/code<br/>
<span class="cmd">uv sync</span><br/><br/>
<span class="comment"># optional: include notebook extras</span><br/>
<span class="cmd">uv sync</span> --extra notebooks<br/><br/>
<span class="comment"># smoke test the install</span><br/>
<span class="cmd">uv run</span> glmhmmt-fit-glmhmmt --help
      </div>
    </div>
    <div class="install-note">
    </div>
    <div>
      <a href="/docs/guide/quickstart" class="btn btn-primary">View quickstart guide →</a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <span>glmhmmt · MAMME TFM · 2025–2026</span>
    <span>Built with <a href="https://astro.build">Astro Starlight</a> · <a href="https://github.com/probml/dynamax">Dynamax</a></span>
  </footer>

  <!-- WAVE ANIMATION -->
  <script>
    (() => {
      const canvas = document.getElementById('waveCanvas');
      // alpha: false tells the browser we don't have transparency, which optimizes GPU compositing
      const ctx = canvas.getContext('2d', { alpha: false });

      const WAVE_COUNT = 22;
      const SPEED = 0.55;

      // ── 1. Pre-compute EVERYTHING into a single cached array ──
      const BASE_COLOR_STOPS = [
        [14,  45,  100],
        [20,  70,  145],
        [30,  106, 191],
        [50,  140, 220],
        [74,  158, 255],
      ];

      const WAVES = new Array(WAVE_COUNT);

      for (let i = 0; i < WAVE_COUNT; i++) {
        const t = i / (WAVE_COUNT - 1);
        
        const scaled = t * (BASE_COLOR_STOPS.length - 1);
        const lo = Math.floor(scaled);
        const hi = Math.min(lo + 1, BASE_COLOR_STOPS.length - 1);
        const f  = scaled - lo;
        const [r1,g1,b1] = BASE_COLOR_STOPS[lo];
        const [r2,g2,b2] = BASE_COLOR_STOPS[hi];
        const r = Math.round(r1 + (r2-r1)*f);
        const g = Math.round(g1 + (g2-g1)*f);
        const b = Math.round(b1 + (b2-b1)*f);
        const a = (0.45 + t * 0.45).toFixed(2);
        
        WAVES[i] = {
          color: `rgba(${r},${g},${b},${a})`,
          lineWidth: 0.9 + t * 0.6,
          yOffsetMult: (t - 0.5) * 0.55,
          phaseOffset: i * 0.22,
          // Pre-multiply by 2 PI here so we do ZERO multiplications per segment
          freq1: (1.8 + i * 0.04) * Math.PI * 2,
          freq2: (2.9 + i * 0.05) * Math.PI * 2,
          phase2Offset: i * 0.3,
          amp1: 38 - Math.abs(t - 0.5) * 40,
          amp2: 18 - Math.abs(t - 0.5) * 18
        };
      }

      let W, H;
      let bgGradient = null;

      function resize() {
        W = window.innerWidth;
        H = window.innerHeight;
        // iOS Safari safeguard: if W is 0, fall back to screen width
        if (W === 0) W = screen.width;
        if (H === 0) H = screen.height;
        
        canvas.width  = W;
        canvas.height = H;
        bgGradient = ctx.createLinearGradient(0, 0, 0, H);
        bgGradient.addColorStop(0,   '#09121e');
        bgGradient.addColorStop(0.5, '#0b1728');
        bgGradient.addColorStop(1,   '#091220');
      }

      window.addEventListener('resize', resize, { passive: true });
      resize();

      let startTime = null;

      function drawFrame(timestamp) {
        if (startTime === null) startTime = timestamp;
        const elapsed = (timestamp - startTime) * 0.001;

        // Catch silent layout shifts on mobile Safari
        if (W !== window.innerWidth && window.innerWidth > 0) {
          resize();
        }

        // Force background fill
        ctx.fillStyle = bgGradient;
        ctx.fillRect(0, 0, W, H);

        const centerY = H * 0.48;
        
        // ── 2. Dynamic path resolution ──
        // We use a high baseline of steps (80) or W/4 to ensure curves look perfectly smooth even on narrow vertical displays (mobile phones)
        const steps = Math.max(80, Math.ceil(W / 4));
        const stepWidth = W / steps;

        for (let i = 0; i < WAVE_COUNT; i++) {
          const w = WAVES[i];
          const yOffset = w.yOffsetMult * H;
          const phase1  = elapsed * SPEED + w.phaseOffset;
          const phase2  = phase1 * 0.7 + w.phase2Offset;

          ctx.beginPath();
          ctx.strokeStyle = w.color;
          ctx.lineWidth   = w.lineWidth;

          for (let s = 0; s <= steps; s++) {
            const nx = s / steps;
            const x  = s * stepWidth;
            const y  = centerY 
                     + yOffset 
                     + Math.sin(nx * w.freq1 + phase1) * w.amp1 
                     + Math.sin(nx * w.freq2 + phase2) * w.amp2;

            if (s === 0) ctx.moveTo(x, y);
            else         ctx.lineTo(x, y);
          }
          ctx.stroke();
        }

        requestAnimationFrame(drawFrame);
      }

      requestAnimationFrame(drawFrame);
    })();

    // Copy to clipboard logic
    document.querySelectorAll('[data-copy-text]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const code = btn.getAttribute('data-copy-text') || '';

        try {
          await navigator.clipboard.writeText(code);

          const copyIcon = btn.querySelector('[data-copy-icon]');
          const checkIcon = btn.querySelector('[data-check-icon]');
          const label = btn.querySelector('[data-copy-label]');
          const oldLabel = label ? label.textContent : null;
          const oldBg = btn.style.background;
          const oldColor = btn.style.color;

          if (copyIcon) copyIcon.style.display = 'none';
          if (checkIcon) checkIcon.style.display = 'block';
          if (label) label.textContent = 'Copied';

          btn.style.background = 'rgba(74, 158, 255, 0.25)';
          btn.style.color = '#fff';

          setTimeout(() => {
            if (copyIcon) copyIcon.style.display = 'block';
            if (checkIcon) checkIcon.style.display = 'none';
            if (label && oldLabel !== null) label.textContent = oldLabel;
            btn.style.background = oldBg;
            btn.style.color = oldColor;
          }, 900);
        } catch (err) {
          console.error('Failed to copy text: ', err);
        }
      });
    });
  </script>
</body>
</html>
